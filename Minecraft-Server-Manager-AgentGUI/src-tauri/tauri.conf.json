{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CraftControl-Agent",
  "version": "2.2.7",
  "identifier": "com.craftcontrol.agent",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CraftControl Agent",
        "width": 500,
        "height": 400,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
