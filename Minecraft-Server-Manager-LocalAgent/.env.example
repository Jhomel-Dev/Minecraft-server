# ==========================================
# Minecraft Server Manager Agent - Environment
# ==========================================

# Port where the Agent will run locally
PORT=3002

# The URL of the central API this agent should report to
API_URL=http://localhost:3000

# Authentication tokens for secure Agent <-> API communication
# Must match the tokens configured in the API's .env file
AUTH_TOKEN=your_secure_auth_token_here
AGENT_SECRET_TOKEN=your_secure_agent_secret_here
