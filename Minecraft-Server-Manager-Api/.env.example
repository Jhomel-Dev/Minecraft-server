# ==========================================
# Minecraft Server Manager API - Environment
# ==========================================

# Port where the Express API will run
PORT=3000

# Port for the WebSocket Socket.io server
SOCKET_PORT=443

# Path where the Minecraft server instances and files will be stored
MINECRAFT_PATH=./minecraft_server

# Authentication tokens for secure Agent <-> API communication
# You should generate a strong random string for these
AUTH_TOKEN=your_secure_auth_token_here
AGENT_SECRET_TOKEN=your_secure_agent_secret_here

# Database connection URL (SQLite is used by default)
DATABASE_URL="file:./dev.db"

# Google OAuth 2.0 Client ID for Google Login
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# JSON Web Token Secrets for securing user sessions
# It is highly recommended to generate 64-character random hex strings
JWT_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here